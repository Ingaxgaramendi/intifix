# Base URL of the Spring Boot backend
VITE_API_BASE_URL=http://localhost:8080
# Native WebSocket (STOMP) endpoint for chat
VITE_WS_URL=ws://localhost:8080/ws/chat

# --- Chat attachments: configure ONE of the two providers below ---
# Cloudinary (unsigned upload preset) — recommended, no backend needed:
# VITE_CLOUDINARY_CLOUD_NAME=tu_cloud
# VITE_CLOUDINARY_UPLOAD_PRESET=tu_preset_unsigned
#
# OR your own upload server (multipart, returns JSON with the public URL):
# VITE_UPLOAD_URL=https://tu-servidor/upload
# VITE_UPLOAD_FIELD=file