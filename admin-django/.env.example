# =============================================================================
# Intifix Admin — Environment variables (template)
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# =============================================================================

# --- Django core ---
DJANGO_SETTINGS_MODULE=intifix_admin.settings.development
DJANGO_SECRET_KEY=change-me-generate-a-50-char-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
DJANGO_TIME_ZONE=America/Lima
DJANGO_LANGUAGE_CODE=es

# --- CORS (admin SPA frontends allowed to call this panel) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- PostgreSQL (local admin metadata: roles, audit pointers, settings) ---
POSTGRES_DB=intifix_admin
POSTGRES_USER=intifix
POSTGRES_PASSWORD=intifix_secret
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://intifix:intifix_secret@postgres:5432/intifix_admin

# --- Redis (cache, throttling, token blacklist) ---
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=300

# --- MongoDB Atlas (audit trail & analytics documents) ---
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=intifix_admin

# --- JWT (validated against the Auth Service public key) ---
# Use RS256 in production: the Auth Service signs, this panel only verifies.
# Must match the Intifix backend (intifix-2026): it signs HS256 tokens with
# JWT_SECRET — set JWT_SIGNING_KEY to that SAME value. The backend sets no
# issuer/audience, so leave those EMPTY.
JWT_ALGORITHM=HS256
JWT_ISSUER=
JWT_AUDIENCE=
JWT_VERIFYING_KEY=
JWT_SIGNING_KEY=<EL-MISMO-JWT_SECRET-de-intifix-2026>
JWT_ACCESS_TOKEN_LIFETIME_MIN=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# =============================================================================
# Backend (intifix-2026) — a single Spring Boot monolith. Point every service
# entry at the same :8080 (use http://host.docker.internal:8080 from Docker).
# =============================================================================
AUTH_SERVICE_URL=http://localhost:8080
USERS_SERVICE_URL=http://localhost:8080
TECHNICIANS_SERVICE_URL=http://localhost:8080
SERVICES_SERVICE_URL=http://localhost:8080
PAYMENTS_SERVICE_URL=http://localhost:8080
GEO_SERVICE_URL=http://localhost:8080
CHAT_SERVICE_URL=http://localhost:8080

# Service-to-service auth (machine token / API key the panel presents)
SERVICE_API_KEY=internal-service-shared-key

# Gateway resilience tuning
GATEWAY_TIMEOUT_SECONDS=10
GATEWAY_MAX_RETRIES=3
GATEWAY_BACKOFF_FACTOR=0.5

# --- Observability ---
LOG_LEVEL=INFO
LOG_JSON=False
SENTRY_DSN=
